# Secrets à configurer dans le dashboard Render → Environment
# (et dans GitHub Secrets pour le pipeline CI/CD)

# Neon PostgreSQL — récupérer dans le dashboard Neon
DB_URL=jdbc:postgresql://<host>.neon.tech:5432/wildlens_staging?sslmode=require
DB_USER=<neon-user>
DB_PASSWORD=<neon-password>
DB_SCHEMA=wildlens_staging

# Générer un secret fort : openssl rand -base64 48
JWT_SECRET=<secret-fort-min-32-chars>

APP_URL=https://wildlens-api-staging.onrender.com

# Render deploy hook — récupérer dans Render → Settings → Deploy Hook
RENDER_DEPLOY_HOOK_STAGING=https://api.render.com/deploy/srv-xxx?key=yyy
